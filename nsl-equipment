 
<!DOCTYPE html>
 
<html lang="en">
 
<head>
 
<meta charset="UTF-8">
 
<meta name="viewport" content="width=device-width, initial-scale=1.0">
 
<title>SSPSL â Equipment History</title>
 
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;600;700&family=Share+Tech+Mono&family=Exo+2:wght@300;400;600;800&display=swap" rel="stylesheet">
 
<style>
 
:root {
 
  --bg: #111827;
 
  --card: #1f2937;
 
  --card2: #273344;
 
  --border: #374151;
 
  --accent: #f97316;
 
  --accent2: #fbbf24;
 
  --green: #22c55e;
 
  --red: #ef4444;
 
  --blue: #38bdf8;
 
  --text: #f1f5f9;
 
  --dim: #94a3b8;
 
}
 
* { box-sizing: border-box; margin: 0; padding: 0; }
 
body { font-family: 'Exo 2', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }
 
 
.header {
 
  background: #0f172a; border-bottom: 2px solid var(--accent);
 
  padding: 12px 16px; display: flex; align-items: center; gap: 12px;
 
  position: sticky; top: 0; z-index: 100; box-shadow: 0 4px 20px rgba(0,0,0,0.5);
 
}
 
.logo {
 
  width: 42px; height: 42px; background: var(--accent); border-radius: 8px;
 
  display: flex; align-items: center; justify-content: center;
 
  font-family: 'Rajdhani', sans-serif; font-weight: 700; font-size: 17px; color: #fff;
 
  box-shadow: 0 0 14px rgba(249,115,22,0.4); flex-shrink: 0;
 
}
 
.header-title { font-family: 'Rajdhani', sans-serif; font-size: 22px; font-weight: 700; letter-spacing: 2px; line-height: 1.2; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: #22c55e; }
 
.header-sub { font-size: 11px; color: #f97316; letter-spacing: 0.5px; margin-top: 2px; user-select: text; }
 
@media(max-width:520px){
 
  .header-title { font-size: 14px; letter-spacing: 1px; white-space: normal; }
 
  .header-sub { font-size: 9px; }
 
}
 
 
.page { display: none; padding: 20px 16px; max-width: 700px; margin: 0 auto; }
 
.page.active { display: block; }
 
 
.card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 20px; margin-bottom: 16px; }
 
.card-title {
 
  font-family: 'Rajdhani', sans-serif; font-size: 15px; font-weight: 700;
 
  letter-spacing: 2px; color: var(--accent); text-transform: uppercase;
 
  margin-bottom: 16px; padding-bottom: 10px; border-bottom: 1px solid var(--border);
 
}
 
 
/* SCAN BUTTON */
 
.scan-btn {
 
  width: 100%; padding: 32px; border: 2px dashed var(--accent); border-radius: 14px;
 
  background: rgba(249,115,22,0.05); cursor: pointer; text-align: center;
 
  transition: all 0.2s; display: flex; flex-direction: column; align-items: center; gap: 10px;
 
  margin-bottom: 16px;
 
}
 
.scan-btn:hover { background: rgba(249,115,22,0.1); border-color: var(--accent2); }
 
.scan-btn:active { transform: scale(0.98); }
 
.scan-icon {
 
  width: 76px; height: 76px; border: 3px solid var(--accent); border-radius: 10px;
 
  display: flex; align-items: center; justify-content: center; font-size: 34px;
 
  position: relative; overflow: hidden;
 
}
 
.scan-icon::after {
 
  content: ''; position: absolute; left: 0; right: 0; height: 2px;
 
  background: var(--accent); box-shadow: 0 0 8px var(--accent);
 
  animation: scanline 2s ease-in-out infinite;
 
}
 
@keyframes scanline { 0%,100%{top:0} 50%{top:calc(100% - 2px)} }
 
.scan-label { font-family: 'Rajdhani', sans-serif; font-size: 24px; font-weight: 700; letter-spacing: 1px; }
 
.scan-sub { font-size: 12px; color: var(--dim); }
 
 
/* CAMERA */
 
.camera-box { display: none; border-radius: 12px; overflow: hidden; position: relative; background: #000; margin-bottom: 16px; }
 
.camera-box.on { display: block; }
 
.camera-box video { width: 100%; display: block; max-height: 320px; object-fit: cover; }
 
.cam-overlay { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; pointer-events: none; }
 
.viewfinder {
 
  width: 190px; height: 190px; border: 3px solid var(--accent); border-radius: 10px;
 
  position: relative; box-shadow: 0 0 0 9999px rgba(0,0,0,0.5);
 
}
 
.viewfinder::after {
 
  content: ''; position: absolute; left: 0; right: 0; height: 2px;
 
  background: linear-gradient(90deg, transparent, var(--accent2), transparent);
 
  animation: scanline 1.6s ease-in-out infinite;
 
}
 
.vf-c { position: absolute; width: 18px; height: 18px; border-color: var(--accent2); border-style: solid; }
 
.vf-c.tl{top:-3px;left:-3px;border-width:4px 0 0 4px;border-radius:4px 0 0 0}
 
.vf-c.tr{top:-3px;right:-3px;border-width:4px 4px 0 0;border-radius:0 4px 0 0}
 
.vf-c.bl{bottom:-3px;left:-3px;border-width:0 0 4px 4px;border-radius:0 0 0 4px}
 
.vf-c.br{bottom:-3px;right:-3px;border-width:0 4px 4px 0;border-radius:0 0 4px 0}
 
.cam-bar {
 
  position: absolute; bottom: 0; left: 0; right: 0; background: rgba(0,0,0,0.7); padding: 8px;
 
  font-family: 'Rajdhani', sans-serif; font-size: 13px; font-weight: 600;
 
  color: var(--accent2); text-align: center; letter-spacing: 1px;
 
}
 
.cam-close {
 
  position: absolute; top: 8px; right: 8px; background: rgba(239,68,68,0.85);
 
  border: none; border-radius: 50%; width: 32px; height: 32px; color: #fff;
 
  font-size: 14px; cursor: pointer; display: flex; align-items: center; justify-content: center;
 
}
 
 
/* FORM */
 
.form-group { margin-bottom: 14px; }
 
label { display: block; font-size: 11px; font-weight: 600; letter-spacing: 1.5px; color: var(--dim); text-transform: uppercase; margin-bottom: 5px; }
 
input, textarea, select {
 
  width: 100%; background: var(--bg); border: 1px solid var(--border); border-radius: 7px;
 
  padding: 10px 12px; color: var(--text); font-family: 'Share Tech Mono', monospace;
 
  font-size: 13px; transition: border 0.2s;
 
}
 
input:focus, textarea:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(249,115,22,0.12); }
 
textarea { resize: vertical; min-height: 80px; }
 
.grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
 
@media(max-width:480px){ .grid2{grid-template-columns:1fr;} }
 
 
.btn {
 
  padding: 11px 20px; border-radius: 8px; border: none;
 
  font-family: 'Rajdhani', sans-serif; font-weight: 700; font-size: 15px;
 
  letter-spacing: 1px; cursor: pointer; transition: all 0.18s;
 
  display: inline-flex; align-items: center; justify-content: center; gap: 7px;
 
}
 
.btn-primary { background: var(--accent); color: #fff; width: 100%; box-shadow: 0 0 16px rgba(249,115,22,0.25); }
 
.btn-primary:hover { background: #ea6c00; transform: translateY(-1px); }
 
.btn-outline { background: transparent; color: var(--dim); border: 1px solid var(--border); }
 
.btn-outline:hover { border-color: var(--accent); color: var(--accent); }
 
.btn-back { background: none; border: none; color: var(--dim); font-family: 'Rajdhani', sans-serif; font-size: 14px; font-weight: 600; cursor: pointer; letter-spacing: 1px; padding: 0; margin-bottom: 16px; display: flex; align-items: center; gap: 5px; }
 
.btn-back:hover { color: var(--text); }
 
.btn-add {
 
  background: #22c55e;
 
  border: none;
 
  color: #fff;
 
  padding: 8px 16px;
 
  border-radius: 8px;
 
  font-family: 'Rajdhani', sans-serif;
 
  font-weight: 700;
 
  font-size: 13px;
 
  letter-spacing: 1px;
 
  cursor: pointer;
 
  transition: all 0.18s;
 
  display: inline-flex;
 
  align-items: center;
 
  gap: 6px;
 
  box-shadow: 0 0 12px rgba(34,197,94,0.3);
 
}
 
.btn-add:hover { background: #16a34a; transform: translateY(-1px); }
 
 
/* EQ INFO */
 
.eq-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
 
@media(max-width:480px){ .eq-info-grid{grid-template-columns:1fr;} }
 
.eq-info-item { background: var(--bg); border: 1px solid var(--border); border-radius: 8px; padding: 10px 12px; }
 
.eq-info-key { font-size: 10px; font-weight: 700; letter-spacing: 1.5px; color: var(--dim); text-transform: uppercase; }
 
.eq-info-val { font-family: 'Share Tech Mono', monospace; font-size: 14px; color: var(--text); margin-top: 3px; }
 
 
/* HISTORY */
 
.history-entry { border: 1px solid var(--border); border-radius: 10px; padding: 14px; margin-bottom: 10px; background: var(--bg); }
 
.history-entry:last-child { margin-bottom: 0; }
 
.h-date { font-family: 'Share Tech Mono', monospace; font-size: 11px; color: var(--dim); margin-bottom: 4px; }
 
.h-task { font-size: 14px; color: var(--text); margin-bottom: 8px; line-height: 1.5; }
 
.h-meta { display: flex; gap: 8px; flex-wrap: wrap; }
 
.badge { padding: 3px 10px; border-radius: 20px; font-size: 11px; font-family: 'Rajdhani', sans-serif; font-weight: 700; }
 
.badge-green { background: rgba(34,197,94,0.12); color: var(--green); border: 1px solid rgba(34,197,94,0.25); }
 
.badge-blue  { background: rgba(56,189,248,0.12); color: var(--blue);  border: 1px solid rgba(56,189,248,0.25); }
 
.badge-orange{ background: rgba(249,115,22,0.12); color: var(--accent);border: 1px solid rgba(249,115,22,0.25); }
 
 
.err-msg { color: var(--red); font-size: 12px; margin-top: 6px; display: none; }
 
.pw-note { font-size: 11px; color: var(--dim); margin-top: 4px; }
 
 
.toast {
 
  position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%);
 
  padding: 11px 22px; border-radius: 8px; font-family: 'Rajdhani', sans-serif;
 
  font-weight: 700; font-size: 14px; letter-spacing: 1px; z-index: 9999;
 
  display: none; white-space: nowrap; box-shadow: 0 4px 20px rgba(0,0,0,0.4);
 
}
 
.toast.on { display: block; animation: slideup 0.2s ease; }
 
@keyframes slideup { from{transform:translateX(-50%) translateY(10px);opacity:0} to{transform:translateX(-50%) translateY(0);opacity:1} }
 
.toast-ok  { background: var(--green); color: #fff; }
 
.toast-err { background: var(--red); color: #fff; }
 
.toast-inf { background: #1e40af; color: #fff; }
 
 
.loading { text-align: center; padding: 40px; color: var(--dim); }
 
.spinner { width: 36px; height: 36px; border: 3px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.7s linear infinite; margin: 0 auto 12px; }
 
@keyframes spin { to{transform:rotate(360deg)} }
 
.empty { text-align: center; padding: 32px; color: var(--dim); font-size: 13px; line-height: 1.8; }
 
 
/* EQUIPMENT LIST ITEMS */
 
.eq-item {
 
  display: flex; align-items: center; justify-content: space-between;
 
  background: var(--bg); border: 1px solid var(--border); border-radius: 8px;
 
  padding: 12px 14px; cursor: pointer; transition: all 0.18s;
 
}
 
.eq-item:hover { border-color: var(--accent); background: rgba(249,115,22,0.06); }
 
.eq-item.highlight { border-color: var(--green); background: rgba(34,197,94,0.07); }
 
.eq-item-name { font-family: 'Rajdhani', sans-serif; font-weight: 700; font-size: 15px; letter-spacing: 1px; }
 
.eq-item-id { font-family: 'Share Tech Mono', monospace; font-size: 11px; color: var(--dim); margin-top: 2px; }
 
.eq-item-arrow { color: var(--accent); font-size: 18px; }
 
 
/* ADMIN BUTTON */
 
.btn-admin {
 
  background: #ef4444;
 
  border: none;
 
  color: #fff;
 
  padding: 8px 14px;
 
  border-radius: 8px;
 
  font-family: 'Rajdhani', sans-serif;
 
  font-weight: 700;
 
  font-size: 13px;
 
  letter-spacing: 1px;
 
  cursor: pointer;
 
  transition: all 0.18s;
 
  display: inline-flex;
 
  align-items: center;
 
  gap: 5px;
 
  box-shadow: 0 0 12px rgba(239,68,68,0.35);
 
}
 
.btn-admin:hover { background: #dc2626; transform: translateY(-1px); }
 
 
/* ADMIN RECORD CARD */
 
.admin-entry {
 
  border: 1px solid var(--border); border-radius: 10px; padding: 14px;
 
  background: var(--bg); position: relative;
 
}
 
.admin-entry-date { font-family: 'Share Tech Mono', monospace; font-size: 11px; color: var(--dim); margin-bottom: 4px; }
 
.admin-entry-task { font-size: 13px; color: var(--text); margin-bottom: 8px; line-height: 1.5; }
 
.admin-entry-actions { display: flex; gap: 8px; margin-top: 10px; }
 
.btn-edit {
 
  padding: 6px 14px; border-radius: 6px; border: 1px solid rgba(56,189,248,0.4);
 
  background: rgba(56,189,248,0.1); color: var(--blue); font-family: 'Rajdhani', sans-serif;
 
  font-weight: 700; font-size: 12px; letter-spacing: 1px; cursor: pointer; transition: all 0.18s;
 
}
 
.btn-edit:hover { background: rgba(56,189,248,0.2); }
 
.btn-delete {
 
  padding: 6px 14px; border-radius: 6px; border: 1px solid rgba(239,68,68,0.4);
 
  background: rgba(239,68,68,0.1); color: var(--red); font-family: 'Rajdhani', sans-serif;
 
  font-weight: 700; font-size: 12px; letter-spacing: 1px; cursor: pointer; transition: all 0.18s;
 
}
 
.btn-delete:hover { background: rgba(239,68,68,0.2); }
 
.entry-num { font-family: 'Share Tech Mono', monospace; font-size: 11px; color: var(--accent); margin-bottom: 6px; font-weight: 700; }
 
 
/* OVERLAY MODAL */
 
.overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.78); backdrop-filter: blur(5px); z-index: 999; align-items: center; justify-content: center; padding: 16px; }
 
.overlay.on { display: flex; }
 
.modal { background: var(--card); border: 1px solid var(--border); border-radius: 14px; padding: 24px; width: 100%; max-width: 380px; animation: pop 0.18s ease; }
 
@keyframes pop { from{transform:scale(0.94);opacity:0} to{transform:scale(1);opacity:1} }
 
.modal-title { font-family: 'Rajdhani', sans-serif; font-size: 20px; font-weight: 700; color: var(--accent); margin-bottom: 14px; letter-spacing: 2px; }
 
.err-msg { color: var(--red); font-size: 12px; margin-top: 5px; display: none; }
 
.pw-note { font-size: 11px; color: var(--dim); margin-top: 4px; }
 
</style>
 
</head>
 
